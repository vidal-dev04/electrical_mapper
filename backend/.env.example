# Local PostgreSQL (Docker)
DATABASE_URL=postgresql://postgres:password@localhost:5432/electrical_network

# Online PostgreSQL providers (choisir une option)

# Supabase (recommandé - gratuit)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Neon (serverless)
# DATABASE_URL=postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require

# Railway
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST].railway.app:5432/railway

# Render
# DATABASE_URL=postgresql://[user]:[password]@[host].render.com/[dbname]

PORT=3000
NODE_ENV=development
